# App
APP_NAME=PersonaGraph Career Agent
APP_ENV=local
APP_VERSION=0.1.0
APP_PHASE=phase_4_hybrid_rag
APP_PHASE_LABEL=Phase 4
APP_DEBUG=true
LOG_LEVEL=INFO
DOCUMENT_UPLOAD_DIR=uploads/documents
DOCUMENT_PARSER_PROVIDER=simple_text
DOCUMENT_PARSE_STRATEGY_VERSION=simple_text_parent_child_v1
DOCUMENT_TEXT_EXTRACTION_MODE=text_only
DOCUMENT_PARENT_TARGET_CHARS=2200
DOCUMENT_CHILD_CHUNK_SIZE=900
DOCUMENT_CHILD_CHUNK_OVERLAP=120
DOCUMENT_OCR_ENABLED=false
DOCUMENT_OCR_PROVIDER=reserved
DOCUMENT_MULTIMODAL_ENABLED=false
DOCUMENT_IMAGE_EXTENSIONS=[".png",".jpg",".jpeg",".webp",".tif",".tiff"]
RAG_ES_INDEX=persona_graph_chunks
RAG_MILVUS_COLLECTION=persona_graph_chunks_v4
RAG_EMBEDDING_DIM=1024
RAG_EMBEDDING_PROVIDER=openai_compatible
RAG_EMBEDDING_FALLBACK_TO_HASH=true

# LLM provider. Keep real values in .env, never commit them.
LLM_API_KEY=
LLM_MODEL_ID=
LLM_BASE_URL=

# Embedding provider. Empty key/base URL reuse LLM_API_KEY and LLM_BASE_URL.
EMBEDDING_API_KEY=
EMBEDDING_MODEL_ID=text-embedding-v4
EMBEDDING_BASE_URL=
EMBEDDING_BATCH_SIZE=10

# Rerank provider. Empty key/base URL reuse LLM_API_KEY and LLM_BASE_URL.
RAG_RERANK_ENABLED=true
RAG_RERANK_CANDIDATE_MULTIPLIER=4
RAG_RERANK_DOCUMENT_MAX_CHARS=2400
RERANK_API_KEY=
RERANK_MODEL_ID=qwen3-rerank
RERANK_BASE_URL=
RERANK_INSTRUCT=Rank the documents by how useful they are as evidence for a career assistant.

SERPAPI_API_KEY=

# Infrastructure. These defaults assume services are exposed on localhost.
DATABASE_URL=postgresql+psycopg://app:change_me_123@127.0.0.1:5432/app_db
REDIS_URL=redis://127.0.0.1:6379/0
MILVUS_URI=http://127.0.0.1:19530
ELASTICSEARCH_URL=http://127.0.0.1:9200
NEO4J_URI=bolt://127.0.0.1:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=
