# App
APP_NAME=PersonaGraph Agent
APP_ENV=local
APP_VERSION=0.1.0
APP_DEBUG=true
LOG_LEVEL=INFO

# LLM provider. Keep real values in .env, never commit them.
LLM_API_KEY=
LLM_MODEL_ID=
LLM_BASE_URL=
SERPAPI_API_KEY=

# Infrastructure. These defaults assume services are exposed on localhost.
DATABASE_URL=postgresql+psycopg://app:change_me_123@127.0.0.1:5432/app_db
REDIS_URL=redis://127.0.0.1:6379/0
MILVUS_URI=http://127.0.0.1:19530
ELASTICSEARCH_URL=http://127.0.0.1:9200
NEO4J_URI=bolt://127.0.0.1:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=
